{
  "name": "@knocklabs/mcp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:client": "cd client && npm ci && npm run build",
    "build": "npm run build:client && npm run cf-typegen && tsc -p .",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build:client && wrangler deploy",
    "dev": "wrangler dev",
    "inspector": "mcp-inspector --config mcp-inspector.json",
    "dev:client": "cd client && npm run dev",
    "start": "wrangler dev",
    "type-check": "npm run cf-typegen && tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"client/src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.1",
    "@knocklabs/agent-toolkit": "^0.5.7",
    "@knocklabs/mgmt": "^0.23.0",
    "@knocklabs/node": "^1.29.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.8.0",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@knocklabs/agent-toolkit": {
      "@knocklabs/mgmt": "$@knocklabs/mgmt",
      "@knocklabs/node": "$@knocklabs/node"
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.76.0"
  }
}
